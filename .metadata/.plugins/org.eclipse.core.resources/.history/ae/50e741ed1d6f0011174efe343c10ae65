    public String submitAnswer(AnswerRequest request) {

        double score =
                evaluationService.evaluateAnswer(
                        request.getAnswer());

        Answer answer = new Answer();

        answer.setAnswerText(request.getAnswer());
        answer.setScore(score);

        if(score >= 8) {
            answer.setFeedback("Excellent Answer");
        }
        else if(score >= 5) {
            answer.setFeedback("Good Answer");
        }
        else {
            answer.setFeedback("Needs Improvement");
        }

        answerRepository.save(answer);

        return "Answer Submitted Successfully";
    }
