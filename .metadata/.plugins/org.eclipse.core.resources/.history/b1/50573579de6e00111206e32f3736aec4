package com.interviewai.service;

import com.interviewai.dto.AnswerRequest;
import com.interviewai.entity.Answer;
import com.interviewai.repository.AnswerRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

@Service
public class AnswerService {

    @Autowired
    private AnswerRepository answerRepository;

    @Autowired
    private EvaluationService evaluationService;

    public String submitAnswer(AnswerRequest request) {

        double score =
                evaluationService.evaluateAnswer(
                        request.getAnswer());

        Answer answer = new Answer();

        answer.setAnswerText(request.getAnswer());
        answer.setScore(score);
        answer.setFeedback("Good attempt");

        answerRepository.save(answer);

        return "Answer Submitted Successfully";
    }
}